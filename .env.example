# ============================================================================
# regime_engine — szablon konfiguracji.
# Skopiuj do `.env` (`cp .env.example .env`) i uzupełnij klucze API.
# Plik `.env` NIE jest wersjonowany (patrz .gitignore). Bez sekretów w kodzie.
# ============================================================================

# --- Klucze API (WYMAGANE od ETAPU E2) ----------------------------------------
# Tiingo (ceny EOD — zastąpiło Stooq 2026-07-07, bo Stooq postawił ścianę anti-bot).
# Darmowy token: https://www.tiingo.com/ (rejestracja → API → Token)
TIINGO_API_KEY=
# FRED (makro: HY OAS, VIX, 10Y, IG OAS). Darmowy klucz: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=
# Finnhub (kalendarz wyników + IPO). Darmowy tier: https://finnhub.io/dashboard
FINNHUB_API_KEY=

# --- Kalendarz zdarzeń ---------------------------------------------------------
# Lista tickerów do /calendar/earnings (edytowalna). Rozdzielone przecinkiem.
EVENT_WATCHLIST=MSFT,GOOGL,AMZN,META,NVDA,AVGO,ORCL,CRWV,MU,SNDK

# --- Parametry silnika (score / tryby) ----------------------------------------
# Okno kroczące do percentyli (liczba sesji). Domyślnie 250 (~rok handlowy).
PERCENTILE_WINDOW=250
# Progi trybów na skali score 0..100 (100 = maksymalny stres / risk-off).
RISK_OFF_TH=65
RISK_ON_TH=35
# Histereza: ile kolejnych sesji po tej samej stronie progu wymusza zmianę trybu.
HYSTERESIS_SESSIONS=2
# Świeżość źródeł score liczona w DNIACH ROBOCZYCH (nie kalendarzowych — inaczej
# fałszywe stale_safe w poniedziałki przez lag publikacji FRED). Przekroczenie = stale_safe.
STALE_CORE_MAX_BDAYS=2   # ceny CORE (Tiingo): dopuszczalny lag w dniach roboczych
STALE_FRED_MAX_BDAYS=3   # makro FRED: większy lag publikacji

# --- Sieć (fetchery) -----------------------------------------------------------
# Timeout pojedynczego żądania HTTP (sekundy). Retry 3x z backoffem 2/4/8 s (stałe w kodzie).
HTTP_TIMEOUT=15

# --- Dashboard -----------------------------------------------------------------
# Katalog docelowy statycznego dashboardu. Domyślnie ./public w katalogu aplikacji.
# Docelowo wskaż docroot subdomeny z panelu, np.:
# PUBLIC_DIR=/home/srv83775/domains/regime.uluru.space/public_html
PUBLIC_DIR=public
# Ścieżka do pliku .htpasswd dla basic-auth dashboardu (POZA docrootem!).
# Pozostaw puste, aby nie generować .htaccess z auth (np. przy PUBLIC_DIR=public lokalnie).
# np.: HTPASSWD_PATH=/home/srv83775/.htpasswd_regime
HTPASSWD_PATH=
